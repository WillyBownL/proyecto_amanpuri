import Loader from '../components/ui/Loader.astro';
import ScrollProgress from '../components/ui/ScrollProgress.astro';
import Header from '../components/layout/Header.astro';
import Hero from '../components/sections/Hero.astro';
import Virginia from '../components/sections/Virginia.astro';
import Services from '../components/sections/Services.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import Contact from '../components/sections/Contact.astro';
import Footer from '../components/layout/Footer.astro';
import WhatsAppFloat from '../components/ui/WhatsAppFloat.astro';
---

