---
const currentYear = new Date().getFullYear();
---

<footer class="py-16 text-white" style="background: var(--deep);">
  <div class="container mx-auto px-6">
    <div class="grid md:grid-cols-4 gap-12 mb-12">
      <div>
        <div class="flex items-center mb-4">
          <div class="w-12 h-12 rounded-full flex items-center justify-center mr-3" style="background: linear-gradient(135deg, #16a34a, #a855f7);">
            <i class="fas fa-spa"></i>
          </div>
          <h3 class="text-2xl font-light">AMANPURI</h3>
        </div>
        <p class="opacity-70 mb-4">Centro de Sanación Holística</p>
        <div class="flex space-x-4">
          <a href="#" class="opacity-70 hover:opacity-100 transition"><i class="fab fa-facebook text-2xl"></i></a>
          <a href="#" class="opacity-70 hover:opacity-100 transition"><i class="fab fa-instagram text-2xl"></i></a>
          <a href="#" class="opacity-70 hover:opacity-100 transition"><i class="fab fa-whatsapp text-2xl"></i></a>
        </div>
      </div>
      <div>
        <h4 class="font-medium mb-4">Servicios</h4>
        <ul class="space-y-2 opacity-70">
          <li><a href="#servicios" class="hover:opacity-100 transition">Masajes</a></li>
          <li><a href="#servicios" class="hover:opacity-100 transition">Camas de cuarzo</a></li>
          <li><a href="#servicios" class="hover:opacity-100 transition">Sauna seco</a></li>
          <li><a href="#servicios" class="hover:opacity-100 transition">Tinajas</a></li>
          <li><a href="#servicios" class="hover:opacity-100 transition">Reiki</a></li>
          <li><a href="#servicios" class="hover:opacity-100 transition">Tarot</a></li>
          <li><a href="#servicios" class="hover:opacity-100 transition">Talleres</a></li>
        </ul>
      </div>
      <div>
        <h4 class="font-medium mb-4">Enlaces</h4>
        <ul class="space-y-2 opacity-70">
          <li><a href="#pas" class="hover:opacity-100 transition">Bienestar</a></li>
          <li><a href="#contacto" class="hover:opacity-100 transition">Contacto</a></li>
        </ul>
      </div>
      <div>
        <h4 class="font-medium mb-4">Contacto</h4>
        <ul class="space-y-2 opacity-70">
          <li>Tierra Amarilla, Atacama</li>
          <li>+569 7196 3263</li>
          <li>contacto@amanpuri.cl</li>
        </ul>
      </div>
    </div>
    <div class="border-t pt-8 text-center opacity-70" style="border-color: rgba(255, 255, 255, 0.1);">
      <p>&copy; {currentYear} Amanpuri. Todos los derechos reservados.</p>
    </div>
  </div>
</footer>
