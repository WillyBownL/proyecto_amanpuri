---
---

<section id="inicio" class="hero relative min-h-screen flex items-center overflow-hidden">
  <div class="hero-bg absolute inset-0" style="background: linear-gradient(135deg, rgba(139, 157, 131, 0.95), rgba(184, 169, 201, 0.85));"></div>
  <div class="hero-pattern absolute inset-0 opacity-5"></div>
  <div class="container mx-auto px-6 relative z-10">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div>
        <span class="inline-block px-6 py-2 rounded-full text-white text-sm font-medium tracking-wider uppercase mb-6" style="background: rgba(255, 255, 255, 0.2); backdrop-filter: blur(10px);">
          <i class="fas fa-map-marker-alt mr-2"></i>Tierra Amarilla, Atacama
        </span>
        <h1 class="text-6xl md:text-8xl font-light text-white mb-6 leading-tight">
          Encuentra tu<br><span class="font-normal">Equilibrio</span><br><span style="color: var(--gold);">Interior</span>
        </h1>
        <div class="w-20 h-1 mb-8" style="background: var(--gold);"></div>
        <p class="text-xl text-white mb-10 leading-relaxed opacity-95 max-w-lg">
          Transformación auténtica a través de terapias holísticas profesionales. Reiki, sanación energética y bienestar integral.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 mb-12">
          <a href="#contacto" class="btn-primary text-center"><i class="fas fa-calendar-check mr-2"></i>Primera Consulta Gratuita</a>
          <a href="#servicios" class="text-center py-3 px-6 rounded-full font-medium border-2 border-white text-white hover:bg-white transition hover:text-gray-700"><i class="fas fa-arrow-down mr-2"></i>Descubrir Más</a>
        </div>
        <div class="flex flex-wrap gap-8 text-white">
          <div>
            <div class="text-4xl font-light mb-2">10+</div>
            <div class="text-sm uppercase tracking-wider opacity-90">Años</div>
          </div>
          <div>
            <div class="text-4xl font-light mb-2">500+</div>
            <div class="text-sm uppercase tracking-wider opacity-90">Clientes</div>
          </div>
          <div>
            <div class="text-4xl font-light mb-2">15+</div>
            <div class="text-sm uppercase tracking-wider opacity-90">Certificaciones</div>
          </div>
        </div>
      </div>
      <div class="hidden md:block floating">
        <img src="/hero-image.jpg" alt="Sanación en Amanpuri" class="rounded-3xl shadow-2xl w-full object-cover" />
      </div>
    </div>
  </div>
</section>
