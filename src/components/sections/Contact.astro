---
interface Props {
  whatsapp?: string;
  instagram?: string;
  phone?: string;
  email?: string;
}

const { 
  whatsapp = '569XXXXXXXX', 
  instagram = 'https://instagram.com/amanpuri',
  phone = '+56 9 XXXX XXXX',
  email = 'contacto@amanpuri.cl'
} = Astro.props;
const whatsappUrl = `https://wa.me/${whatsapp.replace(/\D/g, '')}`;
---

<section id="contacto" class="py-32" style="background: var(--cream);">
  <div class="container mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-16 max-w-7xl mx-auto">
      <div>
        <span class="text-sm uppercase tracking-widest font-medium" style="color: var(--sage);">Contáctanos</span>
        <div class="w-20 h-1 my-4" style="background: linear-gradient(90deg, var(--gold), var(--lavender));"></div>
        <h2 class="text-5xl font-light mb-6" style="color: var(--deep);">Da el Primer Paso hacia tu Transformación</h2>
        <p class="text-lg mb-10" style="color: var(--deep); opacity: 0.8;">Agenda tu consulta gratuita y descubre cómo podemos ayudarte.</p>
        
        <div class="space-y-6 mb-10">
          <div class="flex items-start">
            <div class="w-14 h-14 rounded-2xl flex items-center justify-center mr-5 shrink-0" style="background: linear-gradient(135deg, var(--sage), var(--lavender));">
              <i class="fas fa-map-marker-alt text-white"></i>
            </div>
            <div>
              <h4 class="font-medium mb-1" style="color: var(--deep);">Ubicación</h4>
              <p style="color: var(--deep); opacity: 0.7;">Tierra Amarilla, Atacama</p>
            </div>
          </div>
          <div class="flex items-start">
            <div class="w-14 h-14 rounded-2xl flex items-center justify-center mr-5 shrink-0" style="background: linear-gradient(135deg, var(--sage), var(--lavender));">
              <i class="fas fa-phone text-white"></i>
            </div>
            <div>
              <h4 class="font-medium mb-1" style="color: var(--deep);">Teléfono</h4>
              <p style="color: var(--deep); opacity: 0.7;">{phone}</p>
            </div>
          </div>
          <div class="flex items-start">
            <div class="w-14 h-14 rounded-2xl flex items-center justify-center mr-5 shrink-0" style="background: linear-gradient(135deg, var(--sage), var(--lavender));">
              <i class="fas fa-clock text-white"></i>
            </div>
            <div>
              <h4 class="font-medium mb-1" style="color: var(--deep);">Horario</h4>
              <p style="color: var(--deep); opacity: 0.7;">Lun-Vie: 10:00-19:00 | Sáb: 10:00-14:00</p>
            </div>
          </div>
        </div>
        
        <div class="flex gap-4">
          <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="bg-green-500 text-white px-6 py-3 rounded-full hover:bg-green-600 transition flex items-center">
            <i class="fab fa-whatsapp mr-2 text-xl"></i>WhatsApp
          </a>
          <a href={instagram} target="_blank" rel="noopener noreferrer" class="bg-pink-500 text-white px-6 py-3 rounded-full hover:bg-pink-600 transition flex items-center">
            <i class="fab fa-instagram mr-2 text-xl"></i>Instagram
          </a>
        </div>
      </div>

      <div class="glass-card rounded-3xl p-10">
        <h3 class="text-3xl font-light mb-8" style="color: var(--deep);">Agenda tu Consulta Gratuita</h3>
        <form class="space-y-6">
          <input type="text" placeholder="Nombre Completo *" class="form-input" required />
          <input type="email" placeholder="Email *" class="form-input" required />
          <input type="tel" placeholder="Teléfono *" class="form-input" required />
          <select class="form-input">
            <option>Terapia de Reiki</option>
            <option>Sanación Energética</option>
            <option>Consultoría</option>
            <option>Paquetes</option>
          </select>
          <textarea rows="4" placeholder="Tu mensaje..." class="form-input"></textarea>
          <button type="submit" class="btn-primary w-full"><i class="fas fa-paper-plane mr-2"></i>Enviar</button>
          <p class="text-sm text-center opacity-70" style="color: var(--deep);">Responderemos en menos de 24 horas</p>
        </form>
      </div>
    </div>
  </div>
</section>
