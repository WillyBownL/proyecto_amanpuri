---
interface Props {
  whatsapp?: string;
  instagram?: string;
  phone?: string;
  email?: string;
}

const { 
  whatsapp = '+569 7196 3263', 
  instagram = 'https://www.instagram.com/amanpuri2022/',
  phone = '+569 7196 3263',
  email = 'contacto@amanpuri.cl'
} = Astro.props;
const whatsappUrl = `https://wa.me/${whatsapp.replace(/\D/g, '')}`;
---

<section id="contacto" class="py-32" style="background: var(--cream);">
  <div class="container mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-16 max-w-7xl mx-auto">
      <div>
        <span class="text-sm uppercase tracking-widest font-medium" style="color: var(--sage);">Contáctanos</span>
        <div class="w-20 h-1 my-4" style="background: linear-gradient(90deg, var(--gold), var(--lavender));"></div>
        <h2 class="text-5xl font-light mb-6" style="color: var(--deep);">Da el Primer Paso hacia tu Transformación</h2>
        <p class="text-lg mb-10" style="color: var(--deep); opacity: 0.8;">Agenda tu consulta gratuita y descubre cómo podemos ayudarte.</p>
        
        <div class="space-y-6 mb-10">
          <div class="flex items-start">
            <div class="w-14 h-14 rounded-2xl flex items-center justify-center mr-5 shrink-0" style="background: linear-gradient(135deg, var(--sage), var(--lavender));">
              <i class="fas fa-map-marker-alt text-white"></i>
            </div>
            <div>
              <h4 class="font-medium mb-1" style="color: var(--deep);">Ubicación</h4>
              <p style="color: var(--deep); opacity: 0.7;">Callejón Esmeralda 10, Tierra Amarilla, Atacama</p>
            </div>
          </div>
          <div class="flex items-start">
            <div class="w-14 h-14 rounded-2xl flex items-center justify-center mr-5 shrink-0" style="background: linear-gradient(135deg, var(--sage), var(--lavender));">
              <i class="fas fa-phone text-white"></i>
            </div>
            <div>
              <h4 class="font-medium mb-1" style="color: var(--deep);">Teléfono</h4>
              <p style="color: var(--deep); opacity: 0.7;">{phone}</p>
            </div>
          </div>
          <div class="flex items-start">
            <div class="w-14 h-14 rounded-2xl flex items-center justify-center mr-5 shrink-0" style="background: linear-gradient(135deg, var(--sage), var(--lavender));">
              <i class="fas fa-clock text-white"></i>
            </div>
            <div>
              <h4 class="font-medium mb-1" style="color: var(--deep);">Horario</h4>
              <p style="color: var(--deep); opacity: 0.7;">Lun-Vie: 10:00-19:00 | Sáb: 10:00-14:00</p>
            </div>
          </div>
        </div>
      </div>

      <div class="glass-card rounded-3xl p-6 overflow-hidden flex flex-col">
        <div class="w-full aspect-[4/3] min-h-[280px] rounded-2xl overflow-hidden mb-6">
          <iframe 
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d113313.86633076066!2d-70.37982106093754!3d-27.436293050039055!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x96981b866e8af441%3A0x1b2b57fc0c0b2572!2sAmanpuri!5e0!3m2!1ses!2scl!4v1774243598180!5m2!1ses!2scl" 
            width="100%" 
            height="100%" 
            style="border:0;" 
            allowfullscreen="" 
            loading="lazy" 
            referrerpolicy="no-referrer-when-downgrade"
            title="Ubicación de Amanpuri en Google Maps"
          ></iframe>
        </div>
        <h3 class="text-2xl font-light mb-2 text-center" style="color: var(--deep);">Agenda tu Consulta Gratuita</h3>
        <p class="mb-6 text-center text-sm" style="color: var(--deep); opacity: 0.8;">Contáctanos directamente por WhatsApp o Instagram</p>
        <div class="flex flex-col sm:flex-row gap-4 w-full justify-center">
          <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="flex items-center justify-center gap-3 bg-[#25D366] text-white px-8 py-4 rounded-full font-semibold hover:bg-[#20bd5a] transition text-lg">
            <i class="fab fa-whatsapp text-3xl"></i>
            <span>WhatsApp</span>
          </a>
          <a href={instagram} target="_blank" rel="noopener noreferrer" class="flex items-center justify-center gap-3 text-white px-8 py-4 rounded-full font-semibold hover:opacity-90 transition text-lg" style="background: linear-gradient(45deg, #f09433, #e6683c, #dc2743, #cc2366);">
            <i class="fab fa-instagram text-3xl"></i>
            <span>Instagram</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
