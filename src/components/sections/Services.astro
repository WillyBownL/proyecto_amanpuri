---
---

<section id="servicios" class="py-32 bg-white">
  <div class="container mx-auto px-6">
    <div class="text-center mb-20">
      <span class="text-sm uppercase tracking-widest font-medium" style="color: var(--sage);">Nuestros Servicios</span>
      <div class="w-20 h-1 mx-auto my-4" style="background: linear-gradient(90deg, var(--gold), var(--lavender));"></div>
      <h2 class="text-5xl md:text-6xl font-light mb-6" style="color: var(--deep);">Servicios que<br>Transforman tu Bienestar</h2>
      <p class="text-xl max-w-2xl mx-auto" style="color: var(--deep); opacity: 0.8;">Descubre nuestras terapias y espacios de sanación en Tierra Amarilla.</p>
    </div>

    <!-- Servicios principales -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 mb-20">
      <!-- Masajes de relajación -->
      <div class="service-card-bg relative overflow-hidden rounded-2xl min-h-[340px] flex flex-col justify-between" style="border: 1px solid rgba(139, 157, 131, 0.25);">
        <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/servicio-masaje.png');"></div>
        <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(245, 241, 232, 0.8), rgba(139, 157, 131, 0.72));"></div>
        <div class="relative z-10 p-6 flex flex-col items-center text-center flex-1">
          <div class="service-icon mb-4">
            <i class="fas fa-spa text-white text-3xl"></i>
          </div>
          <h3 class="text-2xl font-light mb-3 text-white" style="text-shadow: 0 1px 3px rgba(0,0,0,0.4);">Masajes de Relajación</h3>
          <p class="mb-3 flex-1 text-white opacity-95" style="text-shadow: 0 1px 2px rgba(0,0,0,0.3);">Libera tensiones musculares y alcanza un estado de calma profunda con nuestros masajes terapéuticos.</p>
          <p class="text-2xl font-bold mb-4 tracking-wide text-white" style="text-shadow: 0 1px 3px rgba(0,0,0,0.4);">$20.000</p>
          <a href="#contacto" class="btn-primary w-full text-center block">Reservar</a>
        </div>
      </div>

      <!-- Tinajas (Destacado - Centro) -->
      <div class="service-card-bg relative overflow-hidden rounded-2xl min-h-[340px] flex flex-col justify-between" style="border: 2px solid rgba(139, 157, 131, 0.4);">
        <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/servicio-tinajas.png');"></div>
        <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(139, 157, 131, 0.78), rgba(184, 169, 201, 0.75));"></div>
        <div class="absolute top-4 right-8 px-6 py-2 rounded-full text-sm font-medium tracking-wider uppercase z-20" style="background: var(--gold); color: white;">Destacado</div>
        <div class="relative z-10 p-6 pt-14 flex flex-col items-center text-center flex-1">
          <div class="service-icon mb-4" style="background: rgba(255, 255, 255, 0.3);">
            <i class="fas fa-hot-tub text-white text-3xl"></i>
          </div>
          <h3 class="text-2xl font-light mb-3 text-white" style="text-shadow: 0 1px 3px rgba(0,0,0,0.4);">Tinajas</h3>
          <p class="mb-3 flex-1 text-white opacity-95" style="text-shadow: 0 1px 2px rgba(0,0,0,0.3);">Baños de vapor en tinaja para purificación corporal, relajación y bienestar integral.</p>
          <p class="text-2xl font-bold mb-4 tracking-wide text-white" style="text-shadow: 0 1px 3px rgba(0,0,0,0.4);">$45.000 <span class="text-sm font-normal opacity-90">para 2 personas</span></p>
          <a href="#contacto" class="block text-center py-3 rounded-full font-medium hover:opacity-90 transition w-full" style="background: white; color: var(--sage);">Reservar</a>
        </div>
      </div>

      <!-- Sauna seco -->
      <div class="service-card-bg relative overflow-hidden rounded-2xl min-h-[340px] flex flex-col justify-between" style="border: 1px solid rgba(139, 157, 131, 0.25);">
        <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/servicio-sauna.png');"></div>
        <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(245, 241, 232, 0.8), rgba(139, 157, 131, 0.72));"></div>
        <div class="relative z-10 p-6 flex flex-col items-center text-center flex-1">
          <div class="service-icon mb-4">
            <i class="fas fa-fire text-white text-3xl"></i>
          </div>
          <h3 class="text-2xl font-light mb-3 text-white" style="text-shadow: 0 1px 3px rgba(0,0,0,0.4);">Sauna Seco</h3>
          <p class="mb-3 flex-1 text-white opacity-95" style="text-shadow: 0 1px 2px rgba(0,0,0,0.3);">Desintoxica tu cuerpo, mejora la circulación y relaja tu mente en nuestro sauna de calor seco.</p>
          <p class="text-2xl font-bold mb-4 tracking-wide text-white" style="text-shadow: 0 1px 3px rgba(0,0,0,0.4);">$20.000</p>
          <a href="#contacto" class="btn-primary w-full text-center block">Reservar</a>
        </div>
      </div>

      <!-- Camas de cuarzo -->
      <div class="service-card-bg relative overflow-hidden rounded-2xl min-h-[340px] flex flex-col justify-between" style="border: 1px solid rgba(139, 157, 131, 0.25);">
        <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/servicio-cuarzo.png');"></div>
        <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(245, 241, 232, 0.8), rgba(74, 88, 89, 0.65));"></div>
        <div class="relative z-10 p-6 flex flex-col items-center text-center flex-1">
          <div class="service-icon mb-4">
            <i class="fas fa-gem text-white text-3xl"></i>
          </div>
          <h3 class="text-2xl font-light mb-3 text-white" style="text-shadow: 0 1px 3px rgba(0,0,0,0.4);">Camas de Cuarzo</h3>
          <p class="mb-3 flex-1 text-white opacity-95" style="text-shadow: 0 1px 2px rgba(0,0,0,0.3);">Experiencia única de sanación energética con las propiedades vibratorias del cuarzo.</p>
          <p class="text-2xl font-bold mb-4 tracking-wide text-white" style="text-shadow: 0 1px 3px rgba(0,0,0,0.4);">$10.000 <span class="text-sm font-normal opacity-90">por 1 hora</span></p>
          <a href="#contacto" class="btn-primary w-full text-center block">Reservar</a>
        </div>
      </div>

      <!-- Reiki -->
      <div class="service-card-bg relative overflow-hidden rounded-2xl min-h-[340px] flex flex-col justify-between" style="border: 1px solid rgba(139, 157, 131, 0.25);">
        <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/servicio-reiki.png');"></div>
        <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(245, 241, 232, 0.8), rgba(139, 157, 131, 0.72));"></div>
        <div class="relative z-10 p-6 flex flex-col items-center text-center flex-1">
          <div class="service-icon mb-4">
            <i class="fas fa-hands text-white text-3xl"></i>
          </div>
          <h3 class="text-2xl font-light mb-3 text-white" style="text-shadow: 0 1px 3px rgba(0,0,0,0.4);">Reiki</h3>
          <p class="mb-3 flex-1 text-white opacity-95" style="text-shadow: 0 1px 2px rgba(0,0,0,0.3);">Sanación energética que equilibra chakras, reduce estrés y promueve el bienestar emocional y físico.</p>
          <p class="text-2xl font-bold mb-4 tracking-wide text-white" style="text-shadow: 0 1px 3px rgba(0,0,0,0.4);">$20.000</p>
          <a href="#contacto" class="btn-primary w-full text-center block">Reservar</a>
        </div>
      </div>

      <!-- Lecturas de Tarot -->
      <div class="service-card-bg relative overflow-hidden rounded-2xl min-h-[340px] flex flex-col justify-between" style="border: 1px solid rgba(139, 157, 131, 0.25);">
        <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/servicio-tarot.png');"></div>
        <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(245, 241, 232, 0.8), rgba(74, 88, 89, 0.6));"></div>
        <div class="relative z-10 p-6 flex flex-col items-center text-center flex-1">
          <div class="service-icon mb-4">
            <i class="fas fa-moon text-white text-3xl"></i>
          </div>
          <h3 class="text-2xl font-light mb-3 text-white" style="text-shadow: 0 1px 3px rgba(0,0,0,0.4);">Lecturas de Tarot</h3>
          <p class="mb-3 flex-1 text-white opacity-95" style="text-shadow: 0 1px 2px rgba(0,0,0,0.3);">Guia espiritual e introspectiva a través de lecturas de tarot personalizadas y profesionales.</p>
          <p class="text-2xl font-bold mb-4 tracking-wide text-white" style="text-shadow: 0 1px 3px rgba(0,0,0,0.4);">$15.000</p>
          <a href="#contacto" class="btn-primary w-full text-center block">Reservar</a>
        </div>
      </div>
    </div>

    <!-- Talleres -->
    <div class="glass-card rounded-3xl p-12">
      <div class="text-center mb-12">
        <span class="text-sm uppercase tracking-widest font-medium" style="color: var(--sage);">Talleres</span>
        <h3 class="text-4xl font-light mb-4 mt-2" style="color: var(--deep);">Aprende con Nosotros</h3>
        <p class="text-xl max-w-2xl mx-auto" style="color: var(--deep); opacity: 0.8;">Aprende a leer el tarot con un método práctico y guiado paso a paso.</p>
      </div>
      <div class="max-w-2xl mx-auto">
        <div class="taller-card relative overflow-hidden rounded-2xl border-2 min-h-[320px] flex flex-col justify-center" style="border-color: rgba(139, 157, 131, 0.3);">
          <div class="taller-card-bg absolute inset-0 bg-cover bg-center" style="background-image: url('/taller-tarot.png');"></div>
          <div class="taller-card-overlay absolute inset-0" style="background: linear-gradient(135deg, rgba(245, 241, 232, 0.82), rgba(139, 157, 131, 0.75));"></div>
          <div class="relative z-10 p-8 flex flex-col items-center text-center transition hover:scale-[1.01]">
            <div class="service-icon mb-4">
              <i class="fas fa-book-open text-white text-3xl"></i>
            </div>
            <h4 class="text-2xl font-light mb-3 text-white" style="text-shadow: 0 1px 3px rgba(0,0,0,0.4);">Taller de Tarot</h4>
            <p class="mb-3 text-white opacity-95" style="text-shadow: 0 1px 2px rgba(0,0,0,0.3);">Aprende a interpretar el tarot desde cero. Método práctico para lecturas personales y profesionales.</p>
            <p class="text-2xl font-bold mb-6 tracking-wide text-white" style="text-shadow: 0 1px 3px rgba(0,0,0,0.4);">$70.000</p>
            <a href="#contacto" class="btn-primary text-center">Más información</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
