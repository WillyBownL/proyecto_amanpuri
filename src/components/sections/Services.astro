---
---

<section id="servicios" class="py-32 bg-white">
  <div class="container mx-auto px-6">
    <div class="text-center mb-20">
      <span class="text-sm uppercase tracking-widest font-medium" style="color: var(--sage);">Nuestros Servicios</span>
      <div class="w-20 h-1 mx-auto my-4" style="background: linear-gradient(90deg, var(--gold), var(--lavender));"></div>
      <h2 class="text-5xl md:text-6xl font-light mb-6" style="color: var(--deep);">Terapias que<br>Transforman Vidas</h2>
    </div>
    <div class="grid md:grid-cols-3 gap-8 mb-20">
      <!-- Reiki -->
      <div
        class="service-card"
        style="background: linear-gradient(135deg, rgba(139, 157, 131, 0.04), rgba(184, 169, 201, 0.06)); border: 1px solid rgba(139, 157, 131, 0.25);"
      >
        <div class="service-icon">
          <i class="fas fa-hands text-white text-3xl"></i>
        </div>
        <h3 class="text-3xl font-light mb-4 text-center" style="color: var(--deep);">Terapia de Reiki</h3>
        <p class="mb-6 text-center" style="color: var(--deep); opacity: 0.8;">Sanación energética profunda que equilibra tus chakras y alivia el estrés.</p>
        <ul class="space-y-3 mb-8">
          <li class="flex items-center" style="color: var(--deep);"><i class="fas fa-check-circle mr-3" style="color: var(--sage);"></i>Reduce ansiedad</li>
          <li class="flex items-center" style="color: var(--deep);"><i class="fas fa-check-circle mr-3" style="color: var(--sage);"></i>Equilibrio energético</li>
          <li class="flex items-center" style="color: var(--deep);"><i class="fas fa-check-circle mr-3" style="color: var(--sage);"></i>Mejora el sueño</li>
        </ul>
        <div class="border-t pt-6" style="border-color: rgba(139, 157, 131, 0.2);">
          <div class="flex justify-between items-center mb-4">
            <span style="color: var(--deep); opacity: 0.7;">Desde</span>
            <span class="text-4xl font-light" style="color: var(--sage);">$30.000</span>
          </div>
          <a href="#contacto" class="btn-primary w-full text-center block">Reservar</a>
        </div>
      </div>

      <!-- Sanación Energética -->
      <div
        class="service-card relative"
        style="background: linear-gradient(135deg, var(--sage), var(--lavender)); color: white; overflow: visible;"
      >
        <div class="absolute -top-4 right-8 px-6 py-2 rounded-full text-sm font-medium tracking-wider uppercase" style="background: var(--gold);">Más Popular</div>
        <div class="service-icon" style="background: rgba(255, 255, 255, 0.3);">
          <i class="fas fa-spa text-white text-3xl"></i>
        </div>
        <h3 class="text-3xl font-light mb-4 text-center">Sanación Energética Integral</h3>
        <p class="mb-6 text-center opacity-95">Combinación avanzada de técnicas para sanación profunda. Ideal para bloqueos emocionales.</p>
        <ul class="space-y-3 mb-8">
          <li class="flex items-center"><i class="fas fa-check-circle mr-3"></i>Limpieza energética</li>
          <li class="flex items-center"><i class="fas fa-check-circle mr-3"></i>Liberación emocional</li>
          <li class="flex items-center"><i class="fas fa-check-circle mr-3"></i>Reconexión espiritual</li>
        </ul>
        <div class="border-t pt-6" style="border-color: rgba(255, 255, 255, 0.3);">
          <div class="flex justify-between items-center mb-4">
            <span>Desde</span>
            <span class="text-4xl font-light">$45.000</span>
          </div>
          <a href="#contacto" class="block text-center py-3 rounded-full font-medium hover:opacity-90 transition" style="background: white; color: var(--sage);">Reservar</a>
        </div>
      </div>

      <!-- Consultoría -->
      <div class="service-card">
        <div class="service-icon">
          <i class="fas fa-leaf text-white text-3xl"></i>
        </div>
        <h3 class="text-3xl font-light mb-4 text-center" style="color: var(--deep);">Consultoría de Bienestar</h3>
        <p class="mb-6 text-center" style="color: var(--deep); opacity: 0.8;">Plan personalizado de transformación con seguimiento continuo.</p>
        <ul class="space-y-3 mb-8">
          <li class="flex items-center" style="color: var(--deep);"><i class="fas fa-check-circle mr-3" style="color: var(--sage);"></i>Plan personalizado</li>
          <li class="flex items-center" style="color: var(--deep);"><i class="fas fa-check-circle mr-3" style="color: var(--sage);"></i>Seguimiento continuo</li>
          <li class="flex items-center" style="color: var(--deep);"><i class="fas fa-check-circle mr-3" style="color: var(--sage);"></i>Herramientas prácticas</li>
        </ul>
        <div class="border-t pt-6" style="border-color: rgba(139, 157, 131, 0.2);">
          <div class="flex justify-between items-center mb-4">
            <span style="color: var(--deep); opacity: 0.7;">Desde</span>
            <span class="text-4xl font-light" style="color: var(--sage);">$35.000</span>
          </div>
          <a href="#contacto" class="btn-primary w-full text-center block">Reservar</a>
        </div>
      </div>
    </div>

    <!-- Paquetes -->
    <div class="glass-card rounded-3xl p-12">
      <div class="text-center mb-12">
        <h3 class="text-4xl font-light mb-4" style="color: var(--deep);">Paquetes Especiales</h3>
        <p class="text-xl" style="color: var(--deep); opacity: 0.8;">Ahorra hasta un 25%</p>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center p-8 rounded-2xl hover:scale-105 transition" style="background: linear-gradient(135deg, rgba(139, 157, 131, 0.1), rgba(184, 169, 201, 0.1)); border: 2px solid rgba(139, 157, 131, 0.3);">
          <div class="text-6xl font-light mb-2" style="color: var(--sage);">3</div>
          <div class="text-xl mb-4" style="color: var(--deep);">Sesiones</div>
          <div class="inline-block px-4 py-2 rounded-full text-sm" style="background: var(--gold); color: white;">Ahorra 15%</div>
        </div>
        <div class="text-center p-8 rounded-2xl shadow-2xl hover:scale-105 transition" style="background: linear-gradient(135deg, var(--sage), var(--lavender)); color: white; transform: scale(1.05);">
          <div class="text-6xl font-light mb-2">6</div>
          <div class="text-xl mb-4">Sesiones</div>
          <div class="inline-block px-4 py-2 rounded-full text-sm" style="background: var(--gold);">Ahorra 20%</div>
        </div>
        <div class="text-center p-8 rounded-2xl hover:scale-105 transition" style="background: linear-gradient(135deg, rgba(139, 157, 131, 0.1), rgba(184, 169, 201, 0.1)); border: 2px solid rgba(139, 157, 131, 0.3);">
          <div class="text-6xl font-light mb-2" style="color: var(--sage);">10</div>
          <div class="text-xl mb-4" style="color: var(--deep);">Sesiones</div>
          <div class="inline-block px-4 py-2 rounded-full text-sm" style="background: var(--gold); color: white;">Ahorra 25%</div>
        </div>
      </div>
    </div>
  </div>
</section>
