---
---

<section id="pas" class="py-32" style="background: var(--cream);">
  <div class="container mx-auto px-6">
    <div class="max-w-6xl mx-auto">
      <div class="grid md:grid-cols-2 gap-8 mb-16 items-stretch">
        <!-- Problema -->
        <div class="p-8 md:p-10 rounded-3xl flex flex-col h-full min-h-[320px]" style="background: rgba(139, 157, 131, 0.08); border: 1px solid rgba(139, 157, 131, 0.2);">
          <h2 class="text-3xl md:text-4xl font-light mb-8" style="color: var(--deep);">¿Te sientes así últimamente?</h2>
          <ul class="space-y-4 text-left">
            <li class="flex items-start gap-4">
              <span class="shrink-0 w-2 h-2 rounded-full mt-2" style="background: var(--sage);"></span>
              <span class="text-lg" style="color: var(--deep);">Estrés constante que no logras soltar</span>
            </li>
            <li class="flex items-start gap-4">
              <span class="shrink-0 w-2 h-2 rounded-full mt-2" style="background: var(--sage);"></span>
              <span class="text-lg" style="color: var(--deep);">Ansiedad, cansancio mental o sensación de desgaste</span>
            </li>
            <li class="flex items-start gap-4">
              <span class="shrink-0 w-2 h-2 rounded-full mt-2" style="background: var(--sage);"></span>
              <span class="text-lg" style="color: var(--deep);">Bloqueos emocionales que afectan tu bienestar diario</span>
            </li>
          </ul>
        </div>

        <!-- Agitar -->
        <div class="p-8 md:p-10 rounded-3xl flex flex-col h-full min-h-[320px]" style="background: rgba(74, 88, 89, 0.06); border: 1px solid rgba(74, 88, 89, 0.12);">
          <h3 class="text-2xl md:text-3xl font-light mb-8" style="color: var(--deep);">Si no lo trabajas...</h3>
          <ul class="space-y-4">
            <li class="flex items-start gap-4">
              <i class="fas fa-exclamation-circle mt-1 shrink-0" style="color: var(--deep); opacity: 0.6;"></i>
              <span class="text-lg" style="color: var(--deep);">Tu energía se sigue drenando</span>
            </li>
            <li class="flex items-start gap-4">
              <i class="fas fa-exclamation-circle mt-1 shrink-0" style="color: var(--deep); opacity: 0.6;"></i>
              <span class="text-lg" style="color: var(--deep);">Tu cuerpo y mente permanecen en tensión</span>
            </li>
            <li class="flex items-start gap-4">
              <i class="fas fa-exclamation-circle mt-1 shrink-0" style="color: var(--deep); opacity: 0.6;"></i>
              <span class="text-lg" style="color: var(--deep);">Te acostumbras a vivir en desequilibrio</span>
            </li>
          </ul>
        </div>
      </div>

      <!-- Solución -->
      <div class="text-center p-10 md:p-14 rounded-3xl" style="background: linear-gradient(135deg, var(--sage), var(--lavender)); color: white;">
        <h3 class="text-3xl md:text-4xl font-light mb-6">La buena noticia</h3>
        <p class="text-xl md:text-2xl leading-relaxed max-w-2xl mx-auto mb-10 opacity-95">
          En Amanpuri ofrecemos masajes de relajación, camas de cuarzo, sauna seco, tinajas, reiki, lecturas de tarot y talleres para tu bienestar integral.
        </p>
        <a href="#contacto" class="btn-primary inline-block" style="background: white; color: var(--sage);">Reserva tu evaluación</a>
      </div>
    </div>
  </div>
</section>
